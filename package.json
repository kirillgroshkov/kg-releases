  "version": "1.0.0",
  "author": "kirillgroshkov <kirill.groshkov5@gmail.com>",
  "private": true,
  "scripts": {
    "prepare": "husky",
    "upd": "pnpm up --no-save",
    "build": "vite build",
    "test": "dev-lib test",
    "lint": "dev-lib lint",
    "bt": "dev-lib typecheck && vue-tsc --noEmit && pnpm build",
    "check": "dev-lib lint && pnpm bt",
    "dev": "vite --port 4100 --open",
    "build-netlify": "vite build",
    "preview": "vite preview --open"
  },
  "dependencies": {
    "@mdi/js": "^7",
    "@naturalcycles/js-lib": "^15",
    "@sentry/vue": "^10",
    "@vueuse/core": "^14",
    "firebase": "^12",
    "pinia": "^3",
    "tslib": "^2",
    "vue": "^3",
    "vue-router": "^5",
    "vuetify": "^4"
  },
  "devDependencies": {
    "@naturalcycles/dev-lib": "^20",
    "@naturalcycles/nodejs-lib": "^15",
    "@types/node": "^25",
    "@typescript/native-preview": "7.0.0-dev.20260328.1",
    "@vitejs/plugin-vue": "^6",
    "husky": "^9",
    "sass": "^1",
    "tsx": "^4",
    "typescript": "~6.0",
    "vite": "^8",
    "vite-bundle-analyzer": "^1",
    "vite-plugin-vuetify": "^2",
    "vue-tsc": "^3"
  },
  "resolutions": {
    "typescript": "~6.0"
  },
  "engines": {
    "node": ">=24.11.0"
  },
